NODE_ENV=production
npm_config_legacy_peer_deps=true

# Backend API Configuration (Appwrite or External)
# Update with your deployed backend URL
VITE_API_BASE_URL=https://your-backend-api-url-here.com

# Appwrite Configuration (if using Appwrite backend)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-project-id
VITE_APPWRITE_API_KEY=your-api-key
