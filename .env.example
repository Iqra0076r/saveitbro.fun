# API Configuration - REQUIRED for production downloads to work
# Local development: http://localhost:8000 (when running Flask backend locally)
# Production: https://your-deployed-backend-url.com (deployed Flask backend URL)
VITE_API_URL=http://localhost:8000

# App Configuration  
VITE_APP_NAME=SaveItBro
VITE_APP_DESCRIPTION=Download YouTube videos instantly

# Feature Flags
VITE_ENABLE_BATCH_DOWNLOAD=true
VITE_ENABLE_PLAYLIST_DOWNLOAD=true

# Appwrite Configuration
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=69d10336001882f5531d
VITE_ENABLE_CHANNEL_DOWNLOAD=false
